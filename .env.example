# Example .env for overzicht_begeleiding_bachelorproeven
# Copy this file to `.env` and edit the values to match your environment.
#
# Notes:
# - For a file-based SQLite DB relative to the project working directory use the
#   "relative" form with three slashes: sqlite:///./opvolging.db
# - For an absolute path on macOS / Linux use four slashes: sqlite:////full/path/to/opvolging.db
# - On Windows you can use: sqlite:///C:/full/path/to/opvolging.db
# - For a temporary in-memory DB (useful for tests): sqlite:///:memory:
#
# After editing `.env` restart your application / language server so it picks up the new values.

# Primary SQLAlchemy database URL used by the app (choose one)
SQLALCHEMY_DATABASE_URL=sqlite:///./opvolging.db
# Example absolute (macOS/Linux):
# SQLALCHEMY_DATABASE_URL=sqlite:////Users/yourname/path/overzicht_begeleiding_bachelorproeven/opvolging.db
# Example absolute (Windows):
# SQLALCHEMY_DATABASE_URL=sqlite:///C:/Users/yourname/path/overzicht_begeleiding_bachelorproeven/opvolging.db
# Example in-memory (for tests):
# SQLALCHEMY_DATABASE_URL=sqlite:///:memory:

# Alias that some libraries use; keep in sync with SQLALCHEMY_DATABASE_URL
DATABASE_URL=${SQLALCHEMY_DATABASE_URL}

# Optional runtime settings
# Set logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Environment marker (development | staging | production)
APP_ENV=development

# If you need to point to a custom Python path or virtualenv, set it outside .env
# (Editors / language servers typically need their interpreter configured separately.)